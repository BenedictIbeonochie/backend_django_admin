# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,admin.aquaai.uk

# Postgres — point this at the SAME DATABASE_URL the main aquaai backend uses
DATABASE_URL=postgres://user:password@host:5432/aquaai?sslmode=require

# GPT-4 — paste your OpenAI key here when ready
OPENAI_API_KEY=sk-REPLACE-WITH-YOUR-GPT-4-KEY
OPENAI_MODEL=gpt-4o

# AI policy thresholds (0-1). A score >= AI_APPROVE_THRESHOLD auto-approves;
# <= AI_REJECT_THRESHOLD auto-rejects; anything in between is flagged for humans.
AI_APPROVE_THRESHOLD=0.80
AI_REJECT_THRESHOLD=0.30

# Slack
SLACK_BOT_TOKEN=xoxb-REPLACE-ME
SLACK_CHANNEL=#aqua-admin-alerts

# Email (SMTP). humara.io Google Workspace example shown.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=admin@humara.io
EMAIL_HOST_PASSWORD=REPLACE-WITH-APP-PASSWORD
DEFAULT_FROM_EMAIL=Aqua Admin <admin@humara.io>

# Super admins — ONLY these accounts get total control.
SUPERADMIN_EMAILS=steven@humara.io,ben@humara.io
